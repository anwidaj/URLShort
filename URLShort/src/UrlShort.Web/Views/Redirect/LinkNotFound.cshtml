@{
    ViewData["Title"] = "Link nie istnieje";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-5">
                <h1 class="h3 mb-3 text-dark">This link doesn't exist</h1>
                <p class="text-muted mb-4">
                    The shortened URL you are trying to use has expired, been deleted, or never existed in our system. Please check the code for any typos.
                </p>
                <a href="@Url.Action("Index", "Url")" class="btn btn-primary px-4">
                    Go to main page
                </a>
            </div>
        </div>
    </div>
</div>