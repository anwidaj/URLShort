@model IEnumerable<URLShort.UrlShort.Core.Models.User>
@{
    ViewData["Title"] = "Admin Panel - Users";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>User Management</h2>
        <a asp-action="Create" class="btn btn-primary">Create New User</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="table-responsive">
        <table class="table table-striped align-middle shadow-sm rounded-3 overflow-hidden">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Created At</th>
                    <th>API Key</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @foreach(var user in Model)
                {
                    <tr>
                        <td class="fw-bold">@user.Id</td>
                        <td>@user.Username</td>
                        <td>
                            <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-secondary")">@user.Role</span>
                        </td>
                        <td class="small text-muted">@user.CreatedAt.ToString("g")</td>
                        <td><code class="text-primary">@user.ApiKey</code></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
