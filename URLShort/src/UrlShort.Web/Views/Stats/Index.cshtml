@model UrlShort.Web.Models.StatsViewModel
@{
    ViewData["Title"] = "Analytics";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-end border-bottom pb-2 mb-4">
        <h2 class="mb-0">Analytics Dashboard</h2>
        <span class="fs-5 text-muted">Total clicks: <strong class="text-dark">@Model.TotalClicks</strong></span>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <h4 class="mb-3">Top 5 Links</h4>
            @if (!Model.TopUrls.Any())
            {
                <p class="text-muted">No data available yet.</p>
            }
            else
            {
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Original Link</th>
                            <th>Short Code</th>
                            <th class="text-end">Clicks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var url in Model.TopUrls)
                        {
                            <tr>
                                <td class="text-truncate" style="max-width: 400px;" title="@url.OriginalUrl">
                                    <a href="@url.OriginalUrl" target="_blank" class="text-decoration-none">@url.OriginalUrl</a>
                                </td>
                                <td>/r/@url.ShortCode</td>
                                <td class="text-end fw-bold">@url.Clicks.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div class="row">
        <!-- Browser Stats -->
        <div class="col-md-4 mb-4">
            <h5 class="border-bottom pb-2">Clicks by Browser</h5>
            @if(!Model.BrowserStats.Any()){
                <p class="text-muted small">No data available.</p>
            }
            else
            {
                <canvas id="browserChart" style="max-height: 250px;"></canvas>

                <!-- Loading Chart.js from CDN -->
                <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
                <script>
                    const ctx = document.getElementById('browserChart').getContext('2d');
                    
                    const chartLabels = @Html.Raw(Json.Serialize(Model.BrowserStats.Keys));
                    const chartData = @Html.Raw(Json.Serialize(Model.BrowserStats.Values));

                    new Chart(ctx, {
                        type: 'pie', 
                        data: {
                            labels: chartLabels,
                            datasets: [{
                                data: chartData,
                                backgroundColor: [
                                    '#0d6efd', '#198754', '#e8b006ff', '#dc3545', '#0dcaf0', '#6c757d'
                                ],
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: {
                                legend: { position: 'bottom' }
                            }
                        }
                    });
                </script>
            }
        </div>

        <!-- Referrer Stats -->
        <div class="col-md-4 mb-4">
            <h5 class="border-bottom pb-2">Traffic Sources</h5>
            @if(!Model.ReferrerStats.Any()){
                <p class="text-muted small">No data available.</p>
            }
            else
            {
                <table class="table table-sm table-borderless mt-2">
                    <tbody>
                        @foreach(var stat in Model.ReferrerStats.OrderByDescending(x => x.Value).Take(6))
                        {
                            <tr>
                                <td class="text-truncate" style="max-width: 150px;" title="@stat.Key">
                                    @(string.IsNullOrWhiteSpace(stat.Key) || stat.Key == "Direct" ? "Direct Traffic" : stat.Key)
                                </td>
                                <td class="text-end fw-bold">@stat.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- Category Stats -->
        <div class="col-md-4 mb-4">
            <h5 class="border-bottom pb-2">Clicks by Category</h5>
            @if(!Model.CategoryStats.Any()){
                <p class="text-muted small">No data available.</p>
            }
            else
            {
                <table class="table table-sm table-borderless mt-2">
                    <tbody>
                        @foreach(var stat in Model.CategoryStats.OrderByDescending(x => x.Value))
                        {
                            <tr>
                                <td>@stat.Key</td>
                                <td class="text-end fw-bold">@stat.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
