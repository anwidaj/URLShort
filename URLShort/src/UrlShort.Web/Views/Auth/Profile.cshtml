@model URLShort.UrlShort.Core.Models.User
@{
    ViewData["Title"] = "Account Settings";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h2 class="card-title h4 mb-4">Security Settings</h2>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger small">@TempData["Error"]</div>
                    }
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success small">@TempData["Success"]</div>
                    }

                    <div class="mb-4 bg-light p-3 rounded-3 border">
                        <label class="form-label small fw-bold text-uppercase text-muted">Your REST API Key</label>
                        <div class="input-group">
                            <input type="text" class="form-control font-monospace" value="@Model.ApiKey" readonly id="apiKeyInput" />
                            <button class="btn btn-outline-secondary" type="button" onclick="navigator.clipboard.writeText(document.getElementById('apiKeyInput').value); alert('API Key copied to clipboard!');">Copy</button>
                        </div>
                        <small class="text-muted mt-2 d-block">Use this key in the <code>X-Api-Key</code> header along with your username in <code>X-Username</code> for API requests.</small>
                    </div>

                    <form asp-action="ChangePassword" method="post">
                        <div class="mb-3">
                            <label for="oldPassword" class="form-label small fw-bold">Old password</label>
                            <input type="password" id="oldPassword" name="oldPassword" class="form-control" required />
                        </div>

                        <hr />

                        <div class="mb-3">
                            <label for="newPassword" class="form-label small fw-bold">New password</label>
                            <input type="password" id="newPassword" name="newPassword" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label for="confirmNewPassword" class="form-label small fw-bold">Confirm new password</label>
                            <input type="password" id="confirmNewPassword" name="confirmNewPassword" class="form-control" required />
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a href="@Url.Action("Index", "Url")" class="text-decoration-none small">Return to profile</a>
                            <button type="submit" class="btn btn-primary">Change password</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>