@{
    ViewData["Title"] = "Link Shortener";
}

<div class="container my-5 py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="display-4 fw-bold text-dark mb-3">Shorten your links</h1>
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a href="@Url.Action("Register", "Auth")" class="btn btn-primary btn-lg px-4 gap-3">Register</a>
                <a href="@Url.Action("Login", "Auth")" class="btn btn-outline-secondary btn-lg px-4">Login</a>
            </div>
        </div>
    </div>

    <div class="row g-4 py-5 row-cols-1 row-cols-lg-3 text-start mt-4">
        <div class="col">
            <h2>Short and secure</h2>
            <p class="text-muted">Transforms your long links into short, aesthetic codes that are easy to share</p>
        </div>
        <div class="col">
            <h2>Full organization</h2>
            <p class="text-muted">Organize your links into categories to keep them tidy and easy to find</p>
        </div>
        <div class="col">
            <h2>Track every click</h2>
            <p class="text-muted">Check detailed stats for each link: views, clicks, and traffic sources</p>
        </div>
    </div>
</div>