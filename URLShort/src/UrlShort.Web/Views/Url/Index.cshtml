@model IEnumerable<URLShort.UrlShort.Core.Models.ShortUrl>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">
    
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show small" role="alert">
            @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show small" role="alert">
            @TempData["Success"]
        </div>
    }

    <!-- Top Section: Horizontal Form -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body">
                    <h3 class="card-title h5 mb-3 fw-bold">Shorten new link</h3>
                    <form asp-action="Create" method="post" class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label for="url" class="form-label small fw-bold">Long URL</label>
                            <input type="url" id="url" name="url" class="form-control" placeholder="https://example.com/very-long-link" required />
                        </div>

                        <div class="col-md-3">
                            <label for="categoryId" class="form-label small fw-bold">Category (Optional)</label>
                            <select id="categoryId" name="categoryId" class="form-select">
                                <option value="">-- Select Category --</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var cat in ViewBag.Categories)
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-2">
                            <label for="customCode" class="form-label small fw-bold">Custom Code (Optional)</label>
                            <div class="input-group">
                                <span class="input-group-text small text-muted bg-light">/r/</span>
                                <input type="text" id="customCode" name="customCode" class="form-control" placeholder="my-promo" maxlength="20" />
                            </div>
                        </div>

                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">Shorten</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Section: Grid -->
    <div class="row">
        <!-- Left Column -->
        <div class="col-xl-3 col-lg-4 mb-4">
            
            <div class="card shadow-sm border-0 rounded-3 mb-4">
                <div class="card-body">
                    <h3 class="card-title h5 mb-3 fw-bold">Manage Categories</h3>
                    <form asp-action="AddCategory" method="post">
                        <div class="mb-3">
                            <label for="categoryName" class="form-label small fw-bold">New Category Name</label>
                            <input type="text" id="categoryName" name="categoryName" class="form-control" placeholder="e.g., Work, Social" required />
                        </div>
                        <button type="submit" class="btn btn-outline-secondary w-100">Add Category</button>
                    </form>

                    @if (ViewBag.Categories != null && ((IEnumerable<URLShort.UrlShort.Core.Models.Category>)ViewBag.Categories).Any())
                    {
                        <hr class="my-4">
                        <ul class="list-group list-group-flush small">
                            @foreach (var cat in ViewBag.Categories)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <span class="fw-bold text-secondary">@cat.Name</span>
                                    <form asp-action="RemoveCategory" asp-route-id="@cat.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this category? Links using this category will NOT be deleted, they will just lose the category label.');">
                                        <button type="submit" class="btn btn-sm text-danger border-0 p-0" title="Delete">X</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body">
                    <h3 class="card-title h5 mb-3 fw-bold">REST API Key</h3>
                    <div class="input-group">
                        <input type="text" class="form-control font-monospace small" value="@ViewBag.ApiKey" readonly id="apiKeyInput" />
                        <button class="btn btn-outline-secondary" type="button" onclick="navigator.clipboard.writeText(document.getElementById('apiKeyInput').value);">Copy</button>
                    </div>
                    <small class="text-muted mt-2 d-block">Use in <code>X-Api-Key</code> header.</small>
                </div>
            </div>

        </div>

        <!-- Right Column -->
        <div class="col-xl-9 col-lg-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body">
                    <h3 class="card-title h5 mb-3 fw-bold">Your Shortened Links</h3>
                    
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-link-45deg display-4"></i>
                            <p class="mt-3 mb-0">You haven't shortened any links yet. Paste a URL above!</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light text-secondary small text-uppercase">
                                    <tr>
                                        <th>Original Link</th>
                                        <th>Short URL</th>
                                        <th>Category</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th class="text-center">Clicks</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        var fullShortUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/r/{item.ShortCode}";
                                        <tr>
                                            <td style="max-width: 150px;" class="text-truncate">
                                                <a href="@item.OriginalUrl" target="_blank" class="text-decoration-none text-dark" title="@item.OriginalUrl">
                                                    @item.OriginalUrl
                                                </a>
                                            </td>
                                            <td>
                                                <a href="@fullShortUrl" target="_blank" class="text-decoration-none fw-bold text-primary">
                                                    @fullShortUrl
                                                </a>
                                            </td>
                                            <td>
                                                @if(item.Category != null)
                                                {
                                                    <span class="badge bg-secondary">@item.Category.Name</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if(item.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Disabled</span>
                                                }
                                            </td>
                                            <td class="small text-muted">
                                                @item.CreatedAt.ToString("MMM dd, yyyy")
                                            </td>
                                            <td class="text-center fw-bold text-secondary">
                                                @item.Clicks.Count
                                            </td>
                                            <td class="text-end">
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this link?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">Delete</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>